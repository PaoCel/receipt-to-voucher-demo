# Copy to .env and fill in. .env is git-ignored.

# OpenAI (default provider)
OPENAI_API_KEY=

# Anthropic (used when --llm-provider anthropic)
ANTHROPIC_API_KEY=

# Optional: override default models
# OPENAI_VISION_MODEL=gpt-4o
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-6

# Optional: confidence threshold for routing to human review (0.0–1.0)
# REVIEW_CONFIDENCE_THRESHOLD=0.75
